# =============================================================================
# Nexus-Shorts-Engine — Environment Template
# Copy this file to `.env` (gitignored) and fill in the real values.
# Variables here are also consumed by MCP-compatible tooling.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
NEXUS_PG_CONNECTION_STRING="Host=localhost;Port=5432;Database=nexus_shorts;Username=nexus;Password=CHANGE_ME"

# --- YouTube Data API v3 ------------------------------------------------------
NEXUS_YOUTUBE_API_KEY=""

# --- Anthropic / Claude -------------------------------------------------------
NEXUS_ANTHROPIC_API_KEY=""
NEXUS_ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# --- ElevenLabs ---------------------------------------------------------------
NEXUS_ELEVENLABS_API_KEY=""
NEXUS_ELEVENLABS_VOICE_FINANCE=""
NEXUS_ELEVENLABS_VOICE_TECHAI=""
NEXUS_ELEVENLABS_VOICE_LEGAL=""

# --- Storyblocks credentials --------------------------------------------------
NEXUS_STORYBLOCKS_EMAIL=""
NEXUS_STORYBLOCKS_PASSWORD=""

# --- Engine paths (Windows-style for the developer workstation) ---------------
NEXUS_OUTPUT_DIR="C:/Users/Clore/Sviluppo/NexusAutomation/Output"
NEXUS_ASSETS_DIR="C:/Users/Clore/Sviluppo/NexusAutomation/Assets"
NEXUS_FFMPEG_PATH="C:/ffmpeg/bin/ffmpeg.exe"
NEXUS_FFPROBE_PATH="C:/ffmpeg/bin/ffprobe.exe"
