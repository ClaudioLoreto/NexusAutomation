# =============================================================================
# Nexus-Shorts-Engine — .gitignore
# =============================================================================

# Secrets / local config -------------------------------------------------------
.env
secrets.json
**/appsettings.Development.json
**/appsettings.Local.json
cookies/
*.cookies.json

# .NET build artifacts ---------------------------------------------------------
bin/
obj/
out/
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio / Rider --------------------------------------------------------
.vs/
.idea/
*.swp

# OS ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# Logs / scratch ---------------------------------------------------------------
*.log
logs/
TestResults/

# Node / Angular ---------------------------------------------------------------
node_modules/
client/nexus-dashboard/dist/
client/nexus-dashboard/.angular/
client/nexus-dashboard/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Playwright runtime artifacts -------------------------------------------------
playwright-report/
test-results/
.playwright/

# Engine runtime artefacts -----------------------------------------------------
Output/
Downloads/
TempRenders/
*.mp4.tmp
